# Supabase configuration for the frontend build.
#
# In production both values are set as Netlify dashboard environment variables and
# are never committed to the repo. For local development, copy this file to
# .env.local and fill in both values.
VITE_SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key
