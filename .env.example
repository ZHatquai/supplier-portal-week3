# Supabase configuration for the frontend build.
#
# VITE_SUPABASE_URL is set in netlify.toml ([build.environment]) because the
# Netlify dashboard environment variables are locked for this site. For local
# development, copy this file to .env.local and fill in both values.
#
# The anon key is NOT committed anywhere in the repo. It must be supplied to the
# production build separately (e.g. a Netlify env var once unlocked). Until it is,
# submissions will fail with an inline retry message.
VITE_SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key
